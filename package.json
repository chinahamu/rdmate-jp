{
  "name": "rdmate-jp",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "dev": "node scripts/ensure-local-dev.mjs && next dev",
    "dev:next": "next dev",
    "setup:local": "node scripts/ensure-local-dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:gui": "playwright test -c playwright.gui.config.ts tests/e2e/gui-guided-workflow.spec.ts",
    "e2e:debug": "playwright test --debug",
    "e2e:codegen": "playwright codegen http://localhost:3000",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "changeset": "pnpm dlx --package @changesets/cli@2.29.7 changeset",
    "version-packages": "pnpm dlx --package @changesets/cli@2.29.7 changeset version",
    "release:status": "pnpm dlx --package @changesets/cli@2.29.7 changeset status --since=main",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "licenses:generate": "node scripts/generate-third-party-licenses.mjs",
    "rdmate": "node scripts/rdmate-cli.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node scripts/seed-sample-data.mjs",
    "db:backup:sqlite": "node scripts/sqlite-backup.mjs",
    "db:restore:sqlite": "node scripts/sqlite-restore.mjs",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "docx": "^9.5.1",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "prisma": "^6.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
