# SQLite database used by Prisma in local development
DATABASE_URL="file:./dev.db"

# Public app metadata
NEXT_PUBLIC_APP_NAME="RDMate JP"

# Operation mode: local | team | institution
RDMATE_USAGE_MODE="local"

# Server-side session settings. Replace in production with a long random value.
SESSION_SECRET="replace-with-at-least-32-random-characters"
RDMATE_SESSION_MAX_AGE_MINUTES="480"
RDMATE_COOKIE_SECURE="false"

# Local development bootstrap
RDMATE_AUTO_SEED="true"
RDMATE_LOCAL_SETUP_ON_DEV="true"

# Institution/server operation safeguards
RDMATE_ENFORCE_HTTPS="false"
RDMATE_BACKUP_DIR="./backups"
RDMATE_ALLOW_RAW_DATA_UPLOAD="false"
