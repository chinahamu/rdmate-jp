NEXT_PUBLIC_APP_NAME="RDMate JP"
DATABASE_URL="file:/data/rdmate.db"
RDMATE_USAGE_MODE="institution"
SESSION_SECRET="change-this-long-random-value-for-docker"
RDMATE_SESSION_MAX_AGE_MINUTES="480"
RDMATE_COOKIE_SECURE="false"
RDMATE_ENFORCE_HTTPS="false"
RDMATE_BACKUP_DIR="/data/backups"
RDMATE_ALLOW_RAW_DATA_UPLOAD="false"
RDMATE_AUTO_SEED="false"
RDMATE_LOCAL_SETUP_ON_DEV="false"
