{
  "id": "generic-jp-v1",
  "name": "汎用DMP 日本語テンプレート",
  "version": "1.0.0",
  "locale": "ja",
  "language": "ja",
  "templateType": "generic",
  "description": "研究開始時に最低限確認したい研究データ管理項目をまとめた汎用テンプレートです。",
  "targetFunder": "general",
  "targetDiscipline": "general",
  "targetFundingAgencyTypes": [
    "kakenhi",
    "jst",
    "amed",
    "foundation",
    "other"
  ],
  "sourceUrl": "https://github.com/chinahamu/rdmate-jp",
  "compatibleTemplateVersions": [
    "1.0.0",
    "2.0.0"
  ],
  "deprecated": {
    "deprecatedAt": "2026-06-29",
    "replacedBy": "generic-jp-v2",
    "reason": "メタデータ拡張と複数保存場所の入力に対応した v2 を既定テンプレートにします。"
  },
  "maintainer": "RDMate JP project",
  "lastReviewedAt": "2026-06-29",
  "lastUpdated": "2026-06-29",
  "sections": [
    {
      "id": "data_description",
      "title": "研究データの概要",
      "description": "研究で生成・収集するデータの内容を整理します。",
      "order": 1,
      "questions": [
        {
          "id": "data_types",
          "label": "生成・収集するデータの種類",
          "type": "textarea",
          "required": true,
          "helpText": "観測データ、実験データ、調査票、画像、コードなどを記載します。",
          "order": 1
        },
        {
          "id": "data_formats",
          "label": "主なファイル形式",
          "type": "text",
          "required": true,
          "helpText": "CSV、JSON、TIFF、FASTQ、PDFなどを記載します。",
          "order": 2
        }
      ]
    },
    {
      "id": "storage_and_sharing",
      "title": "保存・共有方針",
      "description": "研究期間中・終了後の保存場所、公開区分、共有範囲を定義します。",
      "order": 2,
      "questions": [
        {
          "id": "storage_location",
          "label": "主な保存場所",
          "type": "text",
          "required": true,
          "helpText": "機関リポジトリ、クラウドストレージ、研究室サーバなどを記載します。",
          "order": 1
        },
        {
          "id": "sharing_policy",
          "label": "公開・共有方針",
          "type": "select",
          "required": true,
          "options": [
            "公開",
            "制限付き公開",
            "非公開"
          ],
          "order": 2
        },
        {
          "id": "retention_period",
          "label": "保持期間",
          "type": "text",
          "required": true,
          "helpText": "例: 研究終了後5年間、論文公開後10年間など。",
          "order": 3
        }
      ]
    },
    {
      "id": "responsibility",
      "title": "責任体制",
      "order": 3,
      "questions": [
        {
          "id": "data_manager",
          "label": "研究データ管理責任者",
          "type": "text",
          "required": true,
          "helpText": "PI、Data Steward、共同研究者など、DMP上の責任者を記載します。",
          "order": 1
        }
      ]
    }
  ]
}
