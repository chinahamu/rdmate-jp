{
  "id": "generic-jp-v2",
  "name": "汎用DMP 日本語テンプレート v2",
  "version": "2.0.0",
  "locale": "ja",
  "language": "ja",
  "templateType": "generic",
  "description": "Phase 3 のテンプレートメタデータと移行に対応した汎用DMPテンプレートです。",
  "targetFunder": "general",
  "targetDiscipline": "general",
  "targetFundingAgencyTypes": [
    "kakenhi",
    "jst",
    "amed",
    "foundation",
    "other"
  ],
  "sourceUrl": "https://github.com/chinahamu/rdmate-jp",
  "compatibleTemplateVersions": [
    "1.0.0",
    "2.0.0"
  ],
  "maintainer": "RDMate JP project",
  "lastReviewedAt": "2026-06-29",
  "lastUpdated": "2026-06-29",
  "sections": [
    {
      "id": "data_description",
      "title": "研究データの概要",
      "description": "生成・収集するデータとメタデータ標準を整理します。",
      "order": 1,
      "questions": [
        {
          "id": "data_types",
          "label": "生成・収集するデータの種類",
          "type": "textarea",
          "required": true,
          "helpText": "観測データ、実験データ、調査票、画像、コードなどを記載します。",
          "order": 1
        },
        {
          "id": "data_formats",
          "label": "主なファイル形式",
          "type": "text",
          "required": true,
          "helpText": "CSV、JSON、TIFF、FASTQ、PDFなどを記載します。",
          "order": 2
        },
        {
          "id": "metadata_standards",
          "label": "利用するメタデータ標準・語彙",
          "type": "textarea",
          "required": false,
          "helpText": "DataCite、Dublin Core、分野別標準、研究室内命名規則などを記載します。",
          "order": 3
        }
      ]
    },
    {
      "id": "storage_and_sharing",
      "title": "保存・共有方針",
      "description": "研究期間中・終了後の保存場所、公開区分、共有範囲を定義します。",
      "order": 2,
      "questions": [
        {
          "id": "storage_locations",
          "label": "主な保存場所",
          "type": "multi_select",
          "required": true,
          "options": [
            "機関リポジトリ",
            "大学提供クラウド",
            "研究室サーバ",
            "外部データリポジトリ",
            "GakuNin RDM",
            "その他"
          ],
          "helpText": "複数の保存場所を選択できます。",
          "order": 1
        },
        {
          "id": "sharing_policy",
          "label": "公開・共有方針",
          "type": "select",
          "required": true,
          "options": [
            "公開",
            "制限付き公開",
            "非公開",
            "未定"
          ],
          "order": 2
        },
        {
          "id": "private_reason",
          "label": "非公開・制限付き公開の理由",
          "type": "textarea",
          "required": false,
          "helpText": "個人情報、契約、知財、研究倫理上の制約などを記載します。",
          "order": 3
        },
        {
          "id": "retention_period",
          "label": "保持期間",
          "type": "text",
          "required": true,
          "helpText": "例: 研究終了後5年間、論文公開後10年間など。",
          "order": 4
        }
      ]
    },
    {
      "id": "responsibility",
      "title": "責任体制",
      "order": 3,
      "questions": [
        {
          "id": "data_manager",
          "label": "研究データ管理責任者",
          "type": "text",
          "required": true,
          "helpText": "PI、Data Steward、共同研究者など、DMP上の責任者を記載します。",
          "order": 1
        },
        {
          "id": "maintainer_contact",
          "label": "DMP更新窓口メールアドレス",
          "type": "text",
          "required": false,
          "helpText": "DMP更新の問い合わせ先を記載します。",
          "order": 2
        }
      ]
    }
  ]
}
